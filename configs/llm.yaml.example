# LLM API configuration for Layer 2 quality judge
# Copy this file to llm.yaml and fill in your credentials:
#   cp configs/llm.yaml.example configs/llm.yaml

backend: "anthropic"                     # "anthropic" or "openai"
api_url: "https://api.anthropic.com"     # API endpoint
api_key: "sk-your-api-key-here"          # API key
model: "claude-sonnet-4-20250514"        # Model name
samples: 50                              # Docs to score per dataset
